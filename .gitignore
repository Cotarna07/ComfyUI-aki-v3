# Workspace git scope: track only agent-owned areas and fixed entry docs.
*

# Keep git metadata and this ignore file.
!.gitignore

# Fixed collaboration entry docs.
!AGENTS.md
!CLAUDE.md

# Agent-owned areas.
!agent-skills/
!agent-skills/**
!agent-projects/
!agent-projects/**

# Collaboration and skill instructions.
!.github/
!.github/**

# Common local/runtime noise (still ignored even if under allowed trees unless explicitly re-included).
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/
**/.cache/
**/cache/
**/runtime/
**/logs/
**/*.log
**/*.tmp
**/*.temp

# Windows/editor noise.
**/.DS_Store
**/Thumbs.db
**/.vscode/

# Model weight files (reference copies should not bloat the repo).
*.pt
*.pth
*.h5
*.pb
*.ckpt
*.weights
*.safetensors
*.onnx

# Reference project static images (workflow diagrams, samples, screenshots).
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.webp
*.svg
*.ico