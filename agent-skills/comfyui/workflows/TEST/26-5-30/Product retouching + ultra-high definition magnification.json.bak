uts":[{"localized_name":"提示词文本","name":"提示词文本","type":"STRING","links":[3]},{"localized_name":"show_help","name":"show_help","type":"STRING","links":null}],"title":"提示词","properties":{"cnr_id":"ComfyUI_Comfyroll_CustomNodes","ver":"d78b780ae43fcf8c6b7c6505e6ffb4584281ceca","Node name for S&R":"CR Prompt Text","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["以产品主体为绝对基准，严格保持其形状、大小、位置和视角不变，智能重构场景空间结构，实现完美匹配。首先，锁定产品边缘轮廓、曲面法线和消失点作为核心约束，并强制场景透视网格与产品的原始透视对齐（包括焦距、视点高度和FOV）。通过三维边界框重建场景深度级别，并反向优化场景拍摄参数，以确保透视兼容性。根据产品的材质特性反向计算光源位置，动态平衡全局光照强度，实现物理层面的光影交互。使用亚像素掩模精确切割产品边缘，生成自适应接触阴影层和环境反射图，并叠加大气透视效果以增强空间一致性。最终，确保产品空间在动态场景中稳定锚定，场景元素的移动严格遵循产品透视规则，实现零变形、100%透视从属、物理级光效和无缝边缘融合的商业级合成效果"],"color":"#322","bgcolor":"#533"},{"id":9,"type":"LayerUtility: ImageScaleByAspectRatio V2","pos":[4366.6133092469445,-1679.02875158623],"size":[317.2681640625,330],"flags":{"collapsed":false},"order":10,"mode":0,"inputs":[{"label":"图像","localized_name":"image","name":"image","shape":7,"type":"IMAGE","link":9},{"label":"遮罩","localized_name":"mask","name":"mask","shape":7,"type":"MASK","link":null},{"label":"aspect_ratio","localized_name":"aspect_ratio","name":"aspect_ratio","type":"COMBO","widget":{"name":"aspect_ratio"},"link":null},{"label":"proportional_width","localized_name":"proportional_width","name":"proportional_width","type":"INT","widget":{"name":"proportional_width"},"link":null},{"label":"proportional_height","localized_name":"proportional_height","name":"proportional_height","type":"INT","widget":{"name":"proportional_height"},"link":null},{"label":"fit","localized_name":"fit","name":"fit","type":"COMBO","widget":{"name":"fit"},"link":null},{"label":"method","localized_name":"method","name":"method","type":"COMBO","widget":{"name":"method"},"link":null},{"label":"round_to_multiple","localized_name":"round_to_multiple","name":"round_to_multiple","type":"COMBO","widget":{"name":"round_to_multiple"},"link":null},{"label":"scale_to_si